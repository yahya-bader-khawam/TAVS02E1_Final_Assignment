<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Space Exploration & Animation</title>
    <style>
        /* CSS: Requirement (b) - Space theme customization */
        body {
            background-color: #0b0d17; /* Deep space black/blue */
            color: #ffffff;
            font-family: 'Segoe UI', Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        h1 {
            color: #4cc9f0;
            text-shadow: 0 0 10px #4cc9f0;
            margin-bottom: 20px;
        }

        .video-container {
            border: 2px solid #4cc9f0;
            box-shadow: 0 0 20px rgba(76, 201, 240, 0.5);
            border-radius: 12px;
            overflow: hidden;
            line-height: 0;
        }

        /* Styling for the space-themed animation element */
        #planet {
            width: 80px;
            height: 80px;
            background: radial-gradient(circle at 30% 30%, #ff9e00, #ff5400);
            border-radius: 50%;
            position: relative;
            margin-top: 40px;
            box-shadow: inset -10px -10px 20px rgba(0,0,0,0.5), 0 0 15px #ff9e00;
        }
    </style>
</head>
<body>

    <h1>Space Exploration</h1>

    <div class="video-container">
        <iframe width="560" height="315" 
                src="https://www.youtube.com/embed/libKVRa01L8" 
                title="YouTube video player" 
                frameborder="0" 
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                allowfullscreen>
        </iframe>
    </div>

    <div id="planet"></div>

    <script>
        const planet = document.getElementById('planet');
        let angle = 0;

        function floatAnimation() {
            // Using Sine waves to create a smooth "floating" bobbing effect
            angle += 0.05;
            const yOffset = Math.sin(angle) * 20; // Moves up and down by 20px
            const xOffset = Math.cos(angle) * 10; // Subtle side-to-side drift
            
            planet.style.transform = `translate(${xOffset}px, ${yOffset}px)`;
            
            requestAnimationFrame(floatAnimation);
        }

        floatAnimation();
    </script>

</body>
</html>
